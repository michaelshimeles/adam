{
  "name": "world-convex",
  "version": "0.1.0",
  "description": "Convex-backed World for the Vercel Workflow SDK (storage, queue, streams on Convex)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
