      "default": "./src/components/*/index.ts"
    }
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@lucide/svelte": "^1.24.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "shadcn-svelte": "^1.4.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
