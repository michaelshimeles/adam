{
  "name": "ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared Geist-themed shadcn-svelte components for the builder and agent apps.",
  "svelte": "./src/index.ts",
  "exports": {
    "./theme.css": "./src/theme.css",
    "./utils": {
      "types": "./src/utils.ts",
      "svelte": "./src/utils.ts",
      "default": "./src/utils.ts"
    },
    "./components/*": {
