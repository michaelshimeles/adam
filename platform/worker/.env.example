# Convex URL of the builder-backend deployment (control plane).
BUILDER_CONVEX_URL=https://<builder-deployment>.convex.cloud

# Must match PLATFORM_WORKER_SECRET on the builder-backend deployment.
PLATFORM_WORKER_SECRET=

# Convex team slug that per-agent projects are created in.
CONVEX_TEAM=rasmic

# Required on hosted workers (Railway, etc.): a Convex personal/team access
# token so the CLI can create per-agent projects without interactive login.
# Locally, `npx convex login` (~/.convex/config.json) is enough and this can
# be omitted. Dashboard → Team Settings → access token, or reuse the token
# from `~/.convex/config.json` ("accessToken").
CONVEX_OVERRIDE_ACCESS_TOKEN=
