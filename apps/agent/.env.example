# Convex deployment that backs the workflow world AND the app data.
# Local dev:   http://127.0.0.1:3210   (from `npx convex dev` in packages/backend)
# Convex cloud: https://<name>.convex.cloud
CONVEX_URL=http://127.0.0.1:3210

# Shared machine-to-machine secret. Must equal the value set on the Convex
# deployment: (cd packages/backend && npx convex env set WORLD_SERVICE_SECRET <value>)
WORLD_SERVICE_SECRET=dev-world-secret

# Where world-convex delivers queue jobs (this eve host's own HTTP origin).
# `eve dev` overrides this automatically with its real dev origin
# (http://127.0.0.1:2000 by default); the value below is for `eve start`.
WORKFLOW_LOCAL_BASE_URL=http://127.0.0.1:3000

# Model credential for the default gateway model (or set ANTHROPIC_API_KEY
# and switch agent.ts to a direct provider model).
AI_GATEWAY_API_KEY=
