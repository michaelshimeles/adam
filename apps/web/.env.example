# Convex deployment the dashboard subscribes to (same one world-convex uses).
# Local dev:    http://127.0.0.1:3210
# Convex cloud: https://<name>.convex.cloud
VITE_CONVEX_URL=http://127.0.0.1:3210

# Where the eve server lives, as seen from the BROWSER.
# Leave unset in local dev: the Vite proxy forwards same-origin /eve/* to
# http://127.0.0.1:2000 (override with EVE_PROXY_TARGET).
# Set to an absolute origin when hosting the UI away from the eve server.
# VITE_EVE_HOST=https://my-eve-host.example.com
